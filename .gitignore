# --- Executables and Binary Files ---
*.exe
*.dll
*.o
*.obj
*.a
*.lib

# --- Project Specifics ---
# Ignore the actual data files generated by your program
*.txt
*.csv
*.dat

# --- FLTK & Library Folders ---
# If you want to keep the source headers in Git but not the heavy compiled libs
# Uncomment the next line if you want to ignore the lib folder you created
# lib/

# --- IDE and Editor Files ---
.vscode/
.idea/
*.swp
*~
.DS_Store

# --- Build Artifacts ---
# If you use a different build directory
build/
bin/

# --- GPIB / Driver Specifics ---
# Usually, you don't want to version the driver DLLs, 
# but you might want to keep the header.
# !ieee-c.h